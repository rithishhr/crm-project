# ═══════════════════════════════════════════════════════════════════════════
# GCC360 CRM — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────
# STEP 1: Copy this file → rename to  .env
# STEP 2: Fill in your values below
# ═══════════════════════════════════════════════════════════════════════════

# ── DATABASE ─────────────────────────────────────────────────────────────────
# Supabase Postgres (production):
# Paste the Supabase connection string here.
# IMPORTANT: if your password contains `@`, it must be URL-encoded as `%40`.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Change this to your Vercel URL when deploying:
FRONTEND_URL=http://localhost:5173

# ── SUPABASE (optional unless your code uses it directly) ────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── JWT SECURITY ─────────────────────────────────────────────────────────────
# Make these LONG and RANDOM — change before deploying!
JWT_ACCESS_SECRET=gcc360-access-secret-change-this-to-something-very-long-and-random-abc123
JWT_REFRESH_SECRET=gcc360-refresh-secret-different-from-access-secret-xyz789-make-it-long

# ── AI AGENTS (FREE) ─────────────────────────────────────────────────────────
# Groq API — FREE at console.groq.com (no credit card needed)
# Gives you: 14,400 requests/day, Llama 3 70B model
# Powers: Chat Assistant, Lead Scoring, Email Drafter, NL2SQL, Deal Risk
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── EMAIL — Gmail SMTP (for sending invite emails) ───────────────────────────
# Use Gmail App Password, NOT your regular password
# How to get App Password:
#   1. Go to myaccount.google.com → Security
#   2. Turn on 2-Step Verification (required)
#   3. Go to App passwords → Other → type "GCC360"
#   4. Copy the 16-character password it shows
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=abcdefghijklmnop
MAIL_FROM="GCC360 CRM <your-gmail@gmail.com>"

# ── EMAIL SCANNER — Gmail IMAP (reads inbox for RFQ leads) ──────────────────
# Same Gmail App Password as above works for both SMTP and IMAP
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-gmail@gmail.com
IMAP_PASS=abcdefghijklmnop
