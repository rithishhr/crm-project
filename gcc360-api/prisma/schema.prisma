generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Strictly for Supabase
  url      = env("DATABASE_URL")
}

model Company {
  id                 String              @id @default(cuid())
  name               String              @db.VarChar(255)
  industry           String              @db.VarChar(100)
  country            String              @db.VarChar(100)
  plan               String              @default("STARTER") @db.VarChar(20)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  activities         Activity[]
  callLogs           CallLog[]
  chatConversations  ChatConversation[]
  clients            Client[]
  contacts           Contact[]
  deals              Deal[]
  emailImportLogs    EmailImportLog[]
  generatedReports   GeneratedReport[]
  integrationConfigs IntegrationConfig[]
  invoices           Invoice[]
  leads              Lead[]
  notifications      Notification[]
  opportunities      Opportunity[]
  reportTemplates    ReportTemplate[]
  socialMediaLeads   SocialMediaLead[]
  tasks              Task[]
  users              User[]

  @@map("companies")
}

model User {
  id               String            @id @default(cuid())
  name             String            @db.VarChar(255)
  email            String            @unique @db.VarChar(255)
  passwordHash     String            @db.VarChar(255)
  role             String            @default("SALESPERSON") @db.VarChar(30)
  department       String?           @db.VarChar(100)
  avatar           String?           @db.VarChar(10)
  avatarUrl        String?           @db.VarChar(500)
  phone            String?           @db.VarChar(50)
  bio              String?
  status           String            @default("ACTIVE") @db.VarChar(20)
  companyId        String
  faceDescriptor   Json?
  biometricEnabled Boolean           @default(false)
  lastLogin        DateTime?
  isFirstLogin     Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  activities       Activity[]
  auditLogs        AuditLog[]
  biometricRecords BiometricRecord[]
  callLogs         CallLog[]
  documents        Document[]
  assignedLeads    Lead[]            @relation("AssignedLeads")
  notifications    Notification[]
  opportunities    Opportunity[]
  refreshTokens    RefreshToken[]
  tasks            Task[]
  company          Company           @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique @db.VarChar(600)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Lead {
  id                 String           @id @default(cuid())
  title              String?          @db.VarChar(255)
  company            String           @db.VarChar(255)
  contactName        String           @db.VarChar(255)
  email              String           @db.VarChar(255)
  phone              String?          @db.VarChar(50)
  country            String?          @db.VarChar(100)
  source             String?          @db.VarChar(100)
  industry           String?          @db.VarChar(100)
  value              Decimal          @default(0) @db.Decimal(15, 2)
  priority           String           @default("MEDIUM") @db.VarChar(20)
  expectedTimeline   String?          @db.VarChar(100)
  status             String           @default("NEW") @db.VarChar(20)
  aiCredibilityScore Int              @default(0)
  aiVerified         Boolean          @default(false)
  aiFraudFlag        Boolean          @default(false)
  aiNotes            String?
  requirements       String?
  internalNotes      String?
  tags               String?          @db.VarChar(500)
  emailSubject       String?          @db.VarChar(500)
  emailBody          String?
  fromEmail          Boolean          @default(false)
  companyId          String
  assignedToId       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  callLogs           CallLog[]
  documents          Document[]
  emailImportLogs    EmailImportLog[]
  assignedTo         User?            @relation("AssignedLeads", fields: [assignedToId], references: [id])
  companyRef         Company          @relation(fields: [companyId], references: [id])
  opportunity        Opportunity?

  @@index([companyId])
  @@index([assignedToId])
  @@map("leads")
}

model Opportunity {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(255)
  company     String    @db.VarChar(255)
  value       Decimal   @default(0) @db.Decimal(15, 2)
  stage       String    @default("QUALIFICATION") @db.VarChar(30)
  probability Int       @default(0)
  riskLevel   String    @default("LOW") @db.VarChar(20)
  closeDate   DateTime
  notes       String?
  companyId   String
  ownerId     String
  leadId      String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  aiQuotes    AIQuote[]
  companyRef  Company   @relation(fields: [companyId], references: [id])
  lead        Lead?     @relation(fields: [leadId], references: [id])
  owner       User      @relation(fields: [ownerId], references: [id])

  @@index([companyId])
  @@index([ownerId])
  @@map("opportunities")
}

model Client {
  id             String    @id @default(cuid())
  name           String    @db.VarChar(255)
  accountType    String    @default("CUSTOMER") @db.VarChar(30)
  industry       String?   @db.VarChar(100)
  country        String?   @db.VarChar(100)
  city           String?   @db.VarChar(100)
  website        String?   @db.VarChar(255)
  contactPerson  String?   @db.VarChar(255)
  contactTitle   String?   @db.VarChar(100)
  email          String?   @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  accountOwner   String?   @db.VarChar(255)
  customerStatus String    @default("PROSPECT") @db.VarChar(20)
  paymentTerms   String?   @db.VarChar(50)
  currency       String    @default("AED") @db.VarChar(10)
  tier           String    @default("SILVER") @db.VarChar(20)
  totalRevenue   Decimal   @default(0) @db.Decimal(15, 2)
  activeDeals    Int       @default(0)
  address1       String?   @db.VarChar(255)
  postalCode     String?   @db.VarChar(20)
  notes          String?
  tags           String?   @db.VarChar(500)
  companyId      String
  since          DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  company        Company   @relation(fields: [companyId], references: [id])
  contacts       Contact[]
  deals          Deal[]
  invoices       Invoice[]

  @@index([companyId])
  @@map("clients")
}

model Contact {
  id                  String    @id @default(cuid())
  firstName           String    @db.VarChar(100)
  lastName            String    @db.VarChar(100)
  clientId            String?
  jobTitle            String?   @db.VarChar(100)
  department          String?   @db.VarChar(100)
  email               String    @db.VarChar(255)
  phone               String?   @db.VarChar(50)
  mobile              String?   @db.VarChar(50)
  ownerId             String?   @db.VarChar(255)
  status              String    @default("ACTIVE") @db.VarChar(20)
  company             String    @db.VarChar(255)
  linkedOpportunities Int       @default(0)
  lastActivity        DateTime?
  notes               String?
  tags                String?   @db.VarChar(500)
  companyId           String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  clientRef           Client?   @relation(fields: [clientId], references: [id])
  companyRef          Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("contacts")
}

model Deal {
  id            String     @id @default(cuid())
  title         String     @db.VarChar(255)
  company       String     @db.VarChar(255)
  value         Decimal    @db.Decimal(15, 2)
  stage         String     @db.VarChar(30)
  closedDate    DateTime
  opportunityId String?
  clientId      String?
  companyId     String
  ownerId       String
  createdAt     DateTime   @default(now())
  callLogs      CallLog[]
  client        Client?    @relation(fields: [clientId], references: [id])
  companyRef    Company    @relation(fields: [companyId], references: [id])
  documents     Document[]

  @@index([companyId])
  @@map("deals")
}

model Task {
  id           String   @id @default(cuid())
  title        String   @db.VarChar(255)
  dueDate      DateTime
  priority     String   @default("MEDIUM") @db.VarChar(20)
  status       String   @default("TODO") @db.VarChar(20)
  description  String?
  relatedTo    String?  @db.VarChar(255)
  assignedToId String
  companyId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignedTo   User     @relation(fields: [assignedToId], references: [id])
  company      Company  @relation(fields: [companyId], references: [id])

  @@index([assignedToId])
  @@index([companyId])
  @@map("tasks")
}

model Activity {
  id          String   @id @default(cuid())
  type        String   @db.VarChar(20)
  description String
  contact     String?  @db.VarChar(255)
  company     String?  @db.VarChar(255)
  createdById String
  companyId   String
  createdAt   DateTime @default(now())
  companyRef  Company  @relation(fields: [companyId], references: [id])
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@map("activities")
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique @db.VarChar(50)
  amount        Decimal  @db.Decimal(15, 2)
  dueDate       DateTime
  status        String   @default("PENDING") @db.VarChar(20)
  items         String?
  clientId      String
  companyId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  client        Client   @relation(fields: [clientId], references: [id])
  companyRef    Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@map("invoices")
}

model AIQuote {
  id            String      @id @default(cuid())
  type          String      @db.VarChar(20)
  basePrice     Decimal     @db.Decimal(15, 2)
  margin        Decimal     @db.Decimal(5, 2)
  vat           Decimal     @db.Decimal(15, 2)
  total         Decimal     @db.Decimal(15, 2)
  confidence    Int
  justification String
  opportunityId String
  createdAt     DateTime    @default(now())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@map("ai_quotes")
}

model Notification {
  id         String   @id @default(cuid())
  type       String   @db.VarChar(50)
  title      String   @db.VarChar(255)
  message    String
  read       Boolean  @default(false)
  link       String?  @db.VarChar(255)
  userId     String
  companyId  String
  createdAt  DateTime @default(now())
  companyRef Company  @relation(fields: [companyId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@map("notifications")
}

model EmailScanLog {
  id          String   @id @default(cuid())
  messageId   String   @unique @db.VarChar(255)
  fromAddress String   @db.VarChar(255)
  subject     String   @db.VarChar(500)
  scannedAt   DateTime @default(now())
  result      String   @db.VarChar(20)
  leadId      String?
  companyId   String

  @@index([companyId])
  @@map("email_scan_logs")
}

model Document {
  id                 String              @id @default(cuid())
  fileName           String              @db.VarChar(255)
  fileUrl            String              @db.VarChar(500)
  documentType       String?             @db.VarChar(50)
  leadId             String?
  dealId             String?
  userId             String
  createdAt          DateTime            @default(now())
  documentExtraction DocumentExtraction?
  deal               Deal?               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead               Lead?               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([dealId])
  @@index([userId])
  @@map("documents")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   @db.VarChar(255)
  entityType String?  @db.VarChar(50)
  entityId   String?  @db.VarChar(36)
  details    Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("audit_logs")
}

model BiometricRecord {
  id              String    @id @default(cuid())
  userId          String
  faceDescriptor  Json
  confidenceScore Float
  enrollmentDate  DateTime
  lastUsed        DateTime?
  successCount    Int       @default(0)
  failureCount    Int       @default(0)
  status          String    @default("ACTIVE") @db.VarChar(20)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("biometric_records")
}

model IntegrationConfig {
  id              String    @id @default(cuid())
  companyId       String
  integrationType String    @db.VarChar(50)
  provider        String    @db.VarChar(100)
  apiKey          String    @db.VarChar(500)
  apiSecret       String?   @db.VarChar(500)
  webhookUrl      String?   @db.VarChar(500)
  webhookSecret   String?   @db.VarChar(500)
  config          Json?
  isActive        Boolean   @default(true)
  lastSyncAt      DateTime?
  errorLog        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  companyRef      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, integrationType, provider])
  @@index([companyId])
  @@map("integration_configs")
}

model EmailImportLog {
  id            String    @id @default(cuid())
  companyId     String
  messageId     String    @db.VarChar(500)
  fromEmail     String    @db.VarChar(255)
  toEmail       String    @db.VarChar(255)
  subject       String    @db.VarChar(500)
  bodyPreview   String?
  fullBody      String?
  attachments   Json?
  processedAt   DateTime?
  status        String    @default("PENDING") @db.VarChar(20)
  leadCreated   Boolean   @default(false)
  leadId        String?
  extractedData Json?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead          Lead?     @relation(fields: [leadId], references: [id])

  @@index([companyId])
  @@index([messageId])
  @@index([status])
  @@map("email_import_logs")
}

model CallLog {
  id             String   @id @default(cuid())
  companyId      String
  userId         String
  leadId         String?
  dealId         String?
  externalCallId String?  @db.VarChar(255)
  phoneNumber    String   @db.VarChar(50)
  duration       Int      @default(0)
  status         String   @db.VarChar(20)
  recordingUrl   String?  @db.VarChar(500)
  transcript     String?
  summary        String?
  sentiment      String?  @db.VarChar(20)
  actionItems    Json?
  notes          String?
  provider       String   @default("VAPI") @db.VarChar(20)
  createdAt      DateTime @default(now())
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal           Deal?    @relation(fields: [dealId], references: [id])
  lead           Lead?    @relation(fields: [leadId], references: [id])
  user           User     @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([leadId])
  @@index([dealId])
  @@map("call_logs")
}

model SocialMediaLead {
  id             String    @id @default(cuid())
  companyId      String
  platform       String    @db.VarChar(50)
  externalLeadId String    @db.VarChar(255)
  firstName      String?   @db.VarChar(100)
  lastName       String?   @db.VarChar(100)
  email          String?   @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  company        String?   @db.VarChar(255)
  message        String?
  campaignId     String?   @db.VarChar(255)
  campaignName   String?   @db.VarChar(255)
  leadFormId     String?   @db.VarChar(255)
  createdLeadId  String?
  status         String    @default("PENDING") @db.VarChar(20)
  syncedToLeads  Boolean   @default(false)
  metadata       Json?
  receivedAt     DateTime
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
  companyRef     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([platform, externalLeadId])
  @@index([companyId])
  @@index([status])
  @@map("social_media_leads")
}

model ChatConversation {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  leadId    String?
  dealId    String?
  title     String?  @db.VarChar(255)
  context   String?
  messages  Json
  status    String   @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([leadId])
  @@index([dealId])
  @@map("chat_conversations")
}

model DocumentExtraction {
  id             String   @id @default(cuid())
  documentId     String   @unique
  extractedText  String
  structuredData Json?
  documentType   String   @db.VarChar(50)
  confidence     Float    @default(0.8)
  processedAt    DateTime @default(now())
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_extractions")
}

model ReportTemplate {
  id          String   @id @default(cuid())
  companyId   String
  name        String   @db.VarChar(255)
  description String?
  type        String   @db.VarChar(50)
  sections    Json
  isDefault   Boolean  @default(false)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("report_templates")
}

model GeneratedReport {
  id          String   @id @default(cuid())
  companyId   String
  templateId  String?
  title       String   @db.VarChar(255)
  reportType  String   @db.VarChar(50)
  filePath    String   @db.VarChar(500)
  fileUrl     String?  @db.VarChar(500)
  filters     Json?
  data        Json?
  generatedBy String   @db.VarChar(255)
  generatedAt DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([generatedAt])
  @@map("generated_reports")
}

model LeadExtended {
  leadId              String    @id @db.VarChar(36)
  importedFromEmail   Boolean   @default(false)
  importedFromSocial  Boolean   @default(false)
  importedFromCall    Boolean   @default(false)
  emailImportLogId    String?
  socialMediaLeadId   String?
  callLogId           String?
  aiExtractionScore   Float     @default(0)
  lastInteractionType String?   @db.VarChar(50)
  lastInteractionDate DateTime?
  conversionFunnel    String?   @db.VarChar(50)
  createdAt           DateTime  @default(now())

  @@map("lead_extended")
}
